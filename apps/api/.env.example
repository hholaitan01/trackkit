# ─── TrackKit API Configuration ───

# Database (Supabase or any PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/trackkit"

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Routing Services (defaults to public OSM infrastructure)
# For production, self-host these on a VPS:
VALHALLA_URL="https://valhalla1.openstreetmap.de"
NOMINATIM_URL="https://nominatim.openstreetmap.org"

# Optional: Supabase (for hosted Postgres + Realtime)
# SUPABASE_URL="https://xxx.supabase.co"
# SUPABASE_ANON_KEY="xxx"
