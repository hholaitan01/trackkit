{
  "name": "trackkit",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time delivery tracking infrastructure for African startups.",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:api": "cd apps/api && npm run dev",
    "dev:dashboard": "cd apps/dashboard && npm run dev",
    "db:migrate": "cd apps/api && npx prisma migrate dev",
    "db:generate": "cd apps/api && npx prisma generate"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
